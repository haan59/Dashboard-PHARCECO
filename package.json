{
    "name": "dashboard-tailwinds",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "sass:build": "sass src/scss/main.scss dist/custom.css --style=expanded",
        "sass:watch": "sass src/scss/main.scss dist/custom.css --watch --style=expanded",
        "tw:build": "postcss src/css/tailwind.css -o dist/main.css",
        "tw:watch": "postcss src/css/tailwind.css -o dist/main.css --watch",
        "build": "npm run sass:build && npm run tw:build",
        "dev": "concurrently \"npm run sass:watch\" \"npm run tw:watch\"",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.1",
        "autoprefixer": "^10.4.27",
        "concurrently": "^9.2.1",
        "postcss": "^8.5.8",
        "postcss-cli": "^11.0.1",
        "sass": "^1.98.0",
        "tailwindcss": "^4.2.1"
    }
}
